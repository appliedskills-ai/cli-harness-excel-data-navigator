# Makefile.vars — parse-only variables, no side effects (safe to include in any order).

SHELL := /bin/bash
.SHELLFLAGS := -euo pipefail -c
.DEFAULT_GOAL := help

ROOT_DIR ?= $(shell git rev-parse --show-toplevel 2>/dev/null || pwd)
NPM ?= $(shell command -v npm 2>/dev/null)

# Default to the PUBLIC npm registry, overridably; never assume an ambient private mirror.
NPM_CONFIG_REGISTRY ?= https://registry.npmjs.org
export NPM_CONFIG_REGISTRY
